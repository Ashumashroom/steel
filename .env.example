# ──────────────────────────────────────────────
# Inference Mode: "huggingface", "ollama", or "groq"
# ──────────────────────────────────────────────
INFERENCE_MODE=huggingface

# ──────────────────────────────────────────────
# HuggingFace Inference API
# ──────────────────────────────────────────────
HF_API_TOKEN=hf_your_token_here
HF_PRIMARY_MODEL=Qwen/Qwen2.5-7B-Instruct
HF_ROUTER_MODEL=meta-llama/Llama-3.2-3B-Instruct

# ──────────────────────────────────────────────
# Ollama (Local)
# ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=qwen2.5:7b
OLLAMA_ROUTER_MODEL=llama3.2:3b

# ──────────────────────────────────────────────
# Groq Cloud (Free Tier)
# ──────────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here
GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
GROQ_ROUTER_MODEL=llama-3.1-8b-instant
